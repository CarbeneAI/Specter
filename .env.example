# ============================================================
# Specter - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Wazuh Connection (REQUIRED)
# ------------------------------------------------------------
# Full URL to your Wazuh Dashboard (includes https://)
WAZUH_DASHBOARD_URL=https://your-wazuh-server

# Wazuh Dashboard admin credentials
WAZUH_DASHBOARD_USER=admin
WAZUH_DASHBOARD_PASSWORD=

# How often to poll Wazuh for new alerts (milliseconds, default 30s)
# WAZUH_POLL_INTERVAL=30000

# Optional: path to a JSONL alerts file (fallback if Wazuh API is unavailable)
# WAZUH_ALERTS_PATH=/path/to/alerts.jsonl

# ------------------------------------------------------------
# AI Chat (REQUIRED for chat features)
# ------------------------------------------------------------
# Anthropic API key - get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# Suricata Suppression (Optional)
# Required only if you want to suppress Suricata rules from the dashboard
# Format: user@hostname or user@ip-address
# ------------------------------------------------------------
SURICATA_SSH_HOST=user@suricata-host

# Path to disable.conf on the remote Suricata host
# SURICATA_DISABLE_CONF_REMOTE=~/suricata/config/disable.conf

# Local copy of disable.conf (managed by Specter)
# SURICATA_DISABLE_CONF_LOCAL=./suricata-disable.conf

# ------------------------------------------------------------
# Wazuh Suppression (Optional)
# Required only if you want to suppress Wazuh rules from the dashboard
# ------------------------------------------------------------
WAZUH_SSH_HOST=user@wazuh-host

# Path to local_rules.xml on the Wazuh server (default is standard location)
# WAZUH_LOCAL_RULES_PATH=/var/ossec/etc/rules/local_rules.xml

# ------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------
# Port for the Specter API + WebSocket server
PORT=4001

# ------------------------------------------------------------
# Client Configuration (prefix with VITE_ for browser access)
# ------------------------------------------------------------
# API URL for the client to reach the server
VITE_API_URL=http://localhost:4001

# WebSocket URL for real-time alert streaming
VITE_WS_URL=ws://localhost:4001/stream
